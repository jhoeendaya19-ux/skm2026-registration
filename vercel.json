{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/sorsogon-kasanggayahan-marathon-2026",
      "destination": "/sorsogon-kasanggayahan-marathon-2026.html"
    },
    {
      "source": "/sorsogon-kasanggayahan-marathon-2026/",
      "destination": "/sorsogon-kasanggayahan-marathon-2026.html"
    },
    {
      "source": "/sorsogon-kasanggayahan-marathon-2026/lgu-registration",
      "destination": "/sorsogon-kasanggayahan-marathon-2026/lgu-registration/index.html"
    },
    {
      "source": "/sorsogon-kasanggayahan-marathon-2026/lgu-registration/",
      "destination": "/sorsogon-kasanggayahan-marathon-2026/lgu-registration/index.html"
    },
    {
      "source": "/sorsogon-kasanggayahan-marathon-2026/lgu",
      "destination": "/sorsogon-kasanggayahan-marathon-2026/lgu/index.html"
    },
    {
      "source": "/sorsogon-kasanggayahan-marathon-2026/lgu/",
      "destination": "/sorsogon-kasanggayahan-marathon-2026/lgu/index.html"
    },
    {
      "source": "/event",
      "destination": "/event.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/completion",
      "destination": "/completion.html"
    },
    {
      "source": "/medical",
      "destination": "/medical.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
